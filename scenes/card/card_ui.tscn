[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/card/card_ui.gd" id="1_script"]

[node name="CardUi" type="PanelContainer"]
custom_minimum_size = Vector2(240, 340)
script = ExtResource("1_script")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="AccentBar" type="ColorRect" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 10)
layout_mode = 2
color = Color(0.85, 0.35, 0.2, 1)

[node name="Art" type="TextureRect" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 120)
layout_mode = 2
stretch_mode = 5

[node name="TitleLabel" type="Label" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 22
text = "Card Name"
horizontal_alignment = 1

[node name="MetaRow" type="HBoxContainer" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="CostLabel" type="Label" parent="MarginContainer/VBoxContainer/MetaRow"]
unique_name_in_owner = true
layout_mode = 2
text = "Total 0"

[node name="BreakdownLabel" type="Label" parent="MarginContainer/VBoxContainer/MetaRow"]
unique_name_in_owner = true
layout_mode = 2
text = "No element breakdown"

[node name="DescriptionLabel" type="Label" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
autowrap_mode = 2
text = "Card description goes here."
